# ── Google Gemini ─────────────────────────────────────────────
# Required for the browser demo (/demo) and real WhatsApp replies.
# Get a key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_key_here

# ── Twilio WhatsApp (optional) ────────────────────────────────
# Only needed for the REAL WhatsApp integration (/api/webhook).
# The browser demo (/demo) and admin dashboard (/admin) work WITHOUT these.
TWILIO_ACCOUNT_SID=your_sid_here
TWILIO_AUTH_TOKEN=your_token_here
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Public base URL of your deployment, used for Twilio signature
# verification. e.g. https://quickreply-ai.vercel.app
PUBLIC_BASE_URL=
